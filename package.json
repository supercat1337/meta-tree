{
    "name": "@supercat1337/meta-tree",
    "version": "2.2.2",
    "description": "A JavaScript library for creating, managing, and serializing hierarchical data structures with fields, sections, and records.",
    "license": "MIT",
    "author": "Albert Bazaleev",
    "type": "module",
    "main": "dist/meta-tree.esm.js",
    "types": "dist/meta-tree.esm.d.ts",
    "exports": {
        ".": {
            "types": "./dist/meta-tree.esm.d.ts",
            "import": "./dist/meta-tree.esm.js"
        },
        "./package.json": "./package.json"
    },
    "engines": {
        "node": ">=14"
    },
    "keywords": [
        "tree",
        "data-structures",
        "serialization",
        "dsl",
        "rpc",
        "schema",
        "metadata",
        "hierarchical-data",
        "macro-preprocessor",
        "code-generation",
        "api-description"
    ],
    "homepage": "https://github.com/supercat1337/meta-tree",
    "repository": {
        "url": "https://github.com/supercat1337/meta-tree"
    },
    "scripts": {
        "clean": "shx rm -rf ./dist && shx mkdir ./dist",
        "build_esm": "rollup ./src/index.js --file ./dist/meta-tree.esm.js --format es",
        "gen_types": "npx tsc --project my.tsconfig.types.json",
        "bundle_types": "node scripts/bundle-types.js",
        "build": "npm run clean && npm run build_esm && npm run gen_types && npm run bundle_types && shx rm -rf dist/types-temp",
        "test": "c8 ava",
        "test:watch": "ava --watch",
        "coverage": "c8 report --reporter=html"
    },
    "devDependencies": {
        "@rollup/plugin-alias": "^6.0.0",
        "ava": "^7.0.0",
        "c8": "^11.0.0",
        "rollup": "^4.60.1",
        "shx": "^0.4.0"
    },
    "ava": {
        "files": [
            "test/**/*.test.js"
        ],
        "nodeArguments": [
            "--experimental-vm-modules"
        ],
        "extensions": [
            "js"
        ]
    },
    "files": [
        "dist/",
        "src/",
        "index.js",
        "README.md",
        "LICENSE"
    ]
}
